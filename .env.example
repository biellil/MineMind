# MineMind — Configuração de desenvolvimento local
# Copie este arquivo para .env e ajuste os valores

# Conexão com servidor Minecraft
MC_HOST=localhost
MC_PORT=25565
MC_USERNAME=MineMind
MC_VERSION=1.21.4

# Percepção — raio de blocos/entidades capturado no WorldSnapshot (D-07)
PERCEPTION_RADIUS=32

# Timeouts de skills em milissegundos (D-13)
NAVIGATE_TIMEOUT_MS=30000
DIG_TIMEOUT_MS=10000

# === Fase 3: LLM local via LM Studio (LLM-01/02/03) ===
# Habilite o servidor em LM Studio (Developer tab → Start Server) e carregue um
# modelo de chat >= 7B com suporte a structured output (json_schema).
# Sem LM Studio rodando, o agente degrada para o arbiter determinístico (D-17) — o loop continua.
LLM_BASE_URL=http://localhost:1234/v1
LLM_MODEL=local-model
# Temperatura baixa favorece structured output estável em modelos locais (D-18)
LLM_TEMPERATURE=0.4

# === Fase 3: disposição / proatividade (D-04/D-12) ===
# Eixo de persona: AUTONOMOUS (sobrevive sozinho, ignora jogadores) ou ASSISTANT (proativo)
DISPOSITION_DEFAULT=AUTONOMOUS
# Camada conversacional: reactive (responde quando falado) ou proactive
PROACTIVITY=reactive

# === Fase 3: deliberação LLM (D-19) ===
# Intervalo mínimo entre deliberações LLM (orçamento de replanejamento; conservador/lento)
REPLAN_MIN_INTERVAL_MS=8000

# === Fase 3: necessidades (NEED-01/02) ===
# Decaimento de curiosidade por ms ignorado (D-09)
CURIOSITY_DECAY_PER_MS=0.00001
# Boost de urgência por ms desde lastSatisfiedAt (anti-starvation monotônico, D-11)
STARVATION_BOOST_PER_MS=0.000005
# Itens-alvo de recurso (satisfação = fração presente no inventário)
RESOURCE_TARGETS=oak_log,cobblestone,bread

# Pesos de necessidade POR DISPOSIÇÃO (D-06/D-10) — opcionais; sobrescrevem os defaults.
# Defaults AUTONOMOUS (equilibrado): survival=1.0 resources=1.0 curiosity=1.0
# NEED_WEIGHT_AUTONOMOUS_SURVIVAL=1.0
# NEED_WEIGHT_AUTONOMOUS_RESOURCES=1.0
# NEED_WEIGHT_AUTONOMOUS_CURIOSITY=1.0
# Defaults ASSISTANT (curiosity reduzida, survival como piso): survival=1.0 resources=0.9 curiosity=0.4
# NEED_WEIGHT_ASSISTANT_SURVIVAL=1.0
# NEED_WEIGHT_ASSISTANT_RESOURCES=0.9
# NEED_WEIGHT_ASSISTANT_CURIOSITY=0.4

# === Fase 3: objetivos (GOAL-01/02) ===
# Limiar de urgência para uma necessidade virar objetivo
GOAL_THRESHOLD=0.5
# Margem de histerese para trocar de objetivo (D-15, alta/conservadora)
HYSTERESIS_MARGIN=0.25
# Limiar de value de survival abaixo do qual é "crítico" (preempção por perigo, D-15)
SURVIVAL_CRITICAL_THRESHOLD=0.3
