# MineMind — Configuração de desenvolvimento local
# Copie este arquivo para .env e ajuste os valores

# Conexão com servidor Minecraft
MC_HOST=localhost
MC_PORT=25565
MC_USERNAME=MineMind
MC_VERSION=1.21.4

# Percepção — raio de blocos/entidades capturado no WorldSnapshot (D-07)
PERCEPTION_RADIUS=32

# Timeouts de skills em milissegundos (D-13)
NAVIGATE_TIMEOUT_MS=30000
DIG_TIMEOUT_MS=10000
